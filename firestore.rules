rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Firestore-only 로그인 모드(무인증) 운영을 위해 모든 컬렉션 접근을 허용합니다.
    // 운영 중 보안이 필요해지면 Firebase Auth + 규칙 강화 구조로 전환해야 합니다.

    match /users/{uid} {
      allow read, write: if true;
    }

    match /schedules/{scheduleId} {
      allow read, write: if true;

      match /members/{memberId} {
        allow read, write: if true;
      }

      match /students/{studentId} {
        allow read, write: if true;
      }
    }

    match /applications/{applicationId} {
      allow read, write: if true;
    }

    match /applicationDrafts/{draftId} {
      allow read, write: if true;
    }

    match /clubRooms/{roomId} {
      allow read, write: if true;
    }

    match /recruitmentCycles/{cycleId} {
      allow read, write: if true;
    }

    match /recruitmentAssignments/{assignmentId} {
      allow read, write: if true;
    }
  }
}
